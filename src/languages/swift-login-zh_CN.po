msgstr "在主题登录页面中输出 Passkey 登录按钮"

msgid "Social Login Buttons"
msgstr "社会化登录按钮组"

msgid "Renders the social login button group on your custom login page."
msgstr "在主题登录页面中输出社会化登录按钮组"

msgid "PHP Template Call"
msgstr "PHP 模板调用"

msgid "Call this function inside your login form template to automatically output all enabled login methods."
msgstr "在主题模板的登录表单内调用此函数，可自动输出所有已启用的登录方式"

msgid "Thank you for using <a href=\"%3$s\" target=\"_blank\" rel=\"noopener\">Swift Login</a>, a <a href=\"%2$s\" target=\"_blank\" rel=\"noopener\">WordPress</a> plugin by <a href=\"%1$s\" target=\"_blank\" rel=\"noopener\">ZevoST</a>."
